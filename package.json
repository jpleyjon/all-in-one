{
  "name": "all-in-one",
  "version": "1.0.0",
  "description": "A comprehensive TypeScript utility library with data structures and algorithms.",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./data-structures": "./dist/lib/data-structures/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "./bin/test",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "typescript",
    "data-structures",
    "algorithms",
    "stack",
    "queue",
    "list",
    "tree",

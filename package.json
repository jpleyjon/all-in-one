{
  "name": "all-in-one",
  "version": "1.0.0",
  "description": "A comprehensive TypeScript utility library with data structures, string helpers, and array utilities.",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./data-structures": "./dist/lib/data-structures/index.js",
    "./string": "./dist/lib/string/index.js",
    "./array": "./dist/lib/array/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "./bin/test",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "typescript",
    "data-structures",
    "algorithms",
    "stack",
    "queue",
    "list",
    "tree",
    "binary-search-tree",
    "graph",
    "hash-table",
    "string",
    "array",
    "utilities"
  ],
  "author": "Joao Ley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpleyjon/all-in-one.git"
  },
  "bugs": {
    "url": "https://github.com/jpleyjon/all-in-one/issues"
  },
  "homepage": "https://github.com/jpleyjon/all-in-one#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "c8": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}

{
  "name": "@jpleyjon/all-in-one",
  "version": "1.1.0",
  "description": "A comprehensive TypeScript utility library with data structures, function, string, array, object, datetime, currency, JSON, number, and validation helpers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./data-structures": {
      "types": "./dist/lib/data-structures/index.d.ts",
      "require": "./dist/lib/data-structures/index.js",
      "default": "./dist/lib/data-structures/index.js"
    },
    "./string": {
      "types": "./dist/lib/string/index.d.ts",
      "require": "./dist/lib/string/index.js",
      "default": "./dist/lib/string/index.js"
    },
    "./array": {
      "types": "./dist/lib/array/index.d.ts",
      "require": "./dist/lib/array/index.js",
      "default": "./dist/lib/array/index.js"
    },
    "./datetime": {
      "types": "./dist/lib/datetime/index.d.ts",
      "require": "./dist/lib/datetime/index.js",
      "default": "./dist/lib/datetime/index.js"
    },
    "./currency": {
      "types": "./dist/lib/currency/index.d.ts",
      "require": "./dist/lib/currency/index.js",
      "default": "./dist/lib/currency/index.js"
    },
    "./object": {
      "types": "./dist/lib/object/index.d.ts",
      "require": "./dist/lib/object/index.js",
      "default": "./dist/lib/object/index.js"
    },
    "./json": {
      "types": "./dist/lib/json/index.d.ts",
      "require": "./dist/lib/json/index.js",
      "default": "./dist/lib/json/index.js"
    },
    "./number": {
      "types": "./dist/lib/number/index.d.ts",
      "require": "./dist/lib/number/index.js",
      "default": "./dist/lib/number/index.js"
    },
    "./validation": {
      "types": "./dist/lib/validation/index.d.ts",
      "require": "./dist/lib/validation/index.js",
      "default": "./dist/lib/validation/index.js"
    },
    "./functions": {
      "types": "./dist/lib/functions/index.d.ts",
      "require": "./dist/lib/functions/index.js",
      "default": "./dist/lib/functions/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "./bin/build",
    "build:local": "./bin/build-local",
    "lint": "./bin/lint",
    "lint:local": "./bin/lint-local",
    "lint:fix": "./bin/lint-fix",
    "lint:fix:local": "./bin/lint-fix-local",
    "format": "./bin/format",
    "format:local": "./bin/format-local",
    "format:check": "./bin/format-check",
    "format:check:local": "./bin/format-check-local",
    "test": "./bin/test",
    "test:local": "./bin/test-local",
    "publish:package": "./bin/publish",
    "publish:package:local": "./bin/publish-local",
    "prepublishOnly": "npm run test && npm run build",
    "hooks:install": "node -e \"const {execSync}=require('child_process'); const fs=require('fs'); const path=require('path'); const src=path.join(process.cwd(),'.githooks','pre-commit'); const dst=path.join(execSync('git rev-parse --git-path hooks').toString().trim(),'pre-commit'); fs.copyFileSync(src,dst); fs.chmodSync(dst,0o755); console.log('Installed pre-commit hook to '+dst);\""
  },
  "keywords": [
    "typescript",
    "typescript-utils",
    "utility-library",
    "functional-programming",
    "immutable",
    "zero-dependency",
    "lodash-alternative",
    "helpers",
    "utils",
    "data-structures",
    "algorithms",
    "stack",
    "queue",
    "list",
    "tree",
    "binary-search-tree",
    "graph",
    "hash-table",
    "string",
    "array",
    "object",
    "datetime",
    "currency",
    "money",
    "json",
    "json-utils",
    "number",
    "number-utils",
    "validation",
    "date-utils",
    "datetime-utils",
    "object-utils",
    "array-utils",
    "string-utils",
    "utilities"
  ],
  "author": "Joao Ley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpleyjon/all-in-one.git"
  },
  "bugs": {
    "url": "https://github.com/jpleyjon/all-in-one/issues"
  },
  "homepage": "https://github.com/jpleyjon/all-in-one#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "c8": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}

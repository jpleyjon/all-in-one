{
  "name": "all-in-one",
  "version": "1.0.0",
  "description": "A comprehensive TypeScript utility library with data structures, string helpers, array utilities, and currency helpers.",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./data-structures": "./dist/lib/data-structures/index.js",
    "./string": "./dist/lib/string/index.js",
    "./array": "./dist/lib/array/index.js",
    "./currency": "./dist/lib/currency/index.js",
    "./datetime": "./dist/lib/datetime/index.js",
    "./object": "./dist/lib/object/index.js",
    "./json": "./dist/lib/json/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "./bin/build",
    "build:local": "./bin/build-local",
    "lint": "./bin/lint",
    "lint:local": "./bin/lint-local",
    "lint:fix": "./bin/lint-fix",
    "lint:fix:local": "./bin/lint-fix-local",
    "format": "./bin/format",
    "format:local": "./bin/format-local",
    "format:check": "./bin/format-check",
    "format:check:local": "./bin/format-check-local",
    "test": "./bin/test",
    "test:local": "./bin/test-local",
    "prepublishOnly": "npm run build:local && npm run test:local"
  },
  "keywords": [
    "typescript",
    "data-structures",
    "algorithms",
    "stack",
    "queue",
    "list",
    "tree",
    "binary-search-tree",
    "graph",
    "hash-table",
    "string",
    "array",
    "object",
    "datetime",
    "currency",
    "json",
    "utilities"
  ],
  "author": "Joao Ley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpleyjon/all-in-one.git"
  },
  "bugs": {
    "url": "https://github.com/jpleyjon/all-in-one/issues"
  },
  "homepage": "https://github.com/jpleyjon/all-in-one#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "c8": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}

    "hash-table"
  ],
  "author": "Joao Ley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpleyjon/all-in-one.git"
  },
  "bugs": {
    "url": "https://github.com/jpleyjon/all-in-one/issues"
  },
  "homepage": "https://github.com/jpleyjon/all-in-one#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
